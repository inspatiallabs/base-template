{
  "$schema": "./.inspatial/schema/deno.json",
  "inspatial": {
    "kit": {
      "server": {
        "port": 6310,
        "strictPort": false,
        "portMetadata": "all",
        "base": "/",
        "host": "localhost",
        "cacheControl": "no-store",
        "progressiveHtmlStream": true,
        "liveReload": true,
        "responseCacheEnabled": true,
        "responseCacheTtlMs": 2000,
        "responseCacheMaxEntries": 256,
        "assetRouteBase": "/asset/"
      },
      "paths": {
        "srcDir": "./src",
        "distDir": "./dist",
        "typesDir": "./.inspatial/types",
        "styleDir": "./.inspatial/style",
        "schemaDir": "./.inspatial/schema",
        "htmlEntry": "./index.html",
        "htmlDist": "./dist/index.html",
        "assetSrcDir": "./src/asset",
        "assetDistDir": "./dist/asset",
        "favicon": "./src/asset/favicon.png",
        "renderEntry": "./src/config/render.ts",
        "windowEntry": "./src/landing/window.tsx",
        "sceneEntry": "./src/app/scene.tsx",
        "componentEntry": "./src/app/component.tsx",
        "themeEntry": "./src/config/theme.ts",
        "cloudEntry": "./src/config/cloud.ts",
        "denoConfig": "./deno.json",
        "projectRoot": ".",
        "cssInput": "./src/config/theme.css",
        "cssOutput": "./dist/kit.css",
        "jsOutput": "./dist/bundle.js",
        "routeManifest": "./.inspatial/route/route-manifest.generated.ts",
        "routeViews": "./.inspatial/route/route-views.generated.ts",
        "routeTypes": "./.inspatial/route/route-types.generated.d.ts",
        "assetManifest": "./.inspatial/asset/asset-manifest.generated.d.ts",
        "cloudTypes": "./.inspatial/cloud/cloud.generated.d.ts"
      },
      "watch": {
        "include": [
          "./src",
          "./index.html"
        ],
        "includeFramework": [
          "@inspatial/kit",
          "../kit/src",
          "../kit/modules"
        ],
        "exclude": [
          "node_modules",
          "dist",
          ".git",
          ".inspatial",
          ".vscode",
          "coverage"
        ]
      },
      "state": {
        "pattern": "explicit"
      },
      "test": {
        "pattern": "bdd"
      },
      "runtime": {
        "markup": "jsx"
      },
      "intelligence": {
        "codegen": true,
        "importStyle": "app",
        "autoImports": {
          "enabled": true,
          "write": true,
          "formats": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "in"
          ],
          "excludeIndex": true
        }
      },
      "build": {
        "js": {
          "entrypoints": [],
          "outputDir": "./dist",
          "output": "",
          "platform": "browser",
          "minify": true,
          "codeSplitting": true,
          "splitStrategy": "route-based",
          "format": "esm",
          "inlineImports": false,
          "external": [],
          "packages": "bundle",
          "write": true,
          "sourcemap": false
        },
        "style": {
          "engine": "iss",
          "input": "./src/config/theme.css",
          "output": "./dist/kit.css",
          "contentGlobs": [
            "src/**/*.{ts,tsx,js,jsx,in}"
          ],
          "pattern": "explicit"
        },
        "html": {
          "enabled": true,
          "preconnectOrigins": [],
          "preloadRouteChunks": false
        },
        "widgetTreeShake": {
          "allowFor": []
        },
        "timing": {
          "debounceMs": 100,
          "waitAttempts": 50,
          "waitIntervalMs": 100,
          "cssStabilizeAttempts": 10,
          "cssStabilizeIntervalMs": 100
        }
      },
      "discovery": {
        "renderSearch": [
          "./render.ts",
          "./src/render.ts",
          "./src/config/render.ts",
          "./config/render.ts",
          "./app/render.ts"
        ],
        "kitRoots": [
          "@inspatial/kit",
          "../kit/src",
          "../kit/modules"
        ]
      },
      "module": {
        "scopes": [
          "@in",
          "@inspatial",
          "@spatial",
          "@xr"
        ],
        "packageManagers": [
          "jsr"
        ],
        "security": "strict"
      }
    }
  },
  "tasks": {
    "dev": "inspatial kit dev",
    "tunnel": "inspatial kit tunnel",
    "build": "inspatial kit build",
    "serve": "inspatial kit dev",
    "kit:lighthouse": "inspatial kit lighthouse",
    "routes": "inspatial kit routes",
    "test": "deno test --allow-all --no-check",
    "benchmark": "deno bench --allow-all --no-check",
    "clean": "inspatial kit clean"
  },
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable",
      "deno.ns"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "@inspatial/kit"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended",
        "jsx",
        "jsr"
      ],
      "include": [
        "no-var",
        "no-window",
        "no-unused-vars",
        "ban-untagged-todo",
        "no-empty-interface",
        "no-slow-types",
        "no-deprecated-deno-api",
        "no-duplicate-case",
        "no-dupe-class-members",
        "camelcase",
        "no-dupe-args",
        "no-sloppy-imports",
        "no-class-assign",
        "no-unsafe-finally",
        "verbatim-module-syntax"
      ],
      "exclude": [
        "no-explicit-any",
        "ban-ts-comment",
        "jsx-no-children-prop",
        "jsx-boolean-value",
        "ban-types",
        "jsx-curly-braces"
      ]
    },
    "exclude": [
      "**/test/**/*",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.test.jsx",
      "**/*.test.js",
      "**/*.spec.ts",
      "**/*.spec.tsx",
      "**/*.spec.jsx",
      "**/*.spec.js",
      "**/*_test.ts",
      "**/*_test.tsx",
      "**/*_test.jsx",
      "**/*_test.js"
    ]
  },
  "imports": {
    "@inspatial/kit": "../../../inspatial-kit/modules/in-runtime/src/jsx-runtime.ts",
